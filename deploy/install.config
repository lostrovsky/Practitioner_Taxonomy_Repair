# ============================================================
# Practitioner Taxonomy Repair -- Installation Configuration
# ============================================================
# Fill in the values below before running install.ps1
# Lines starting with # are comments and ignored
#
# install.ps1 reads this file and:
#   1. Generates <InstallDir>\Practitioner_Taxonomy_Repair\env.properties
#      (consumed by the loader at run time via --env-file)
#   2. Generates <InstallDir>\Practitioner_Taxonomy_Repair\PractitionerTaxonomyRepair.properties
#      (consumed by the repair jar directly)
#   3. Substitutes SQLCMD_PATH into the deployed run_repair.ps1
#   4. Optionally applies the DDL via sqlcmd
# ============================================================

# --- Database Connection ---
# JDBC connection string for SQL Server. install.ps1 parses this for sqlcmd
# (DDL apply) AND derives db.url for PractitionerTaxonomyRepair.properties.
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=INTEGRATION_PLUS_DB;trustServerCertificate=true;

# Database credentials. Used by both the repair jar (writes to cpe_repair)
# and the loader (reads the cpe_repair TVF). Must have:
#   SELECT on cpe_master.practitioner, cpe_master.practitioner_taxonomy, cpe_xref.taxonomy
#   INSERT/UPDATE on cpe_repair.*
DB_USER=
DB_PASSWORD=

# --- HRP Web Service ---
# Base URL for HRP connector services (no trailing slash).
# Example: http://hrp-server:9191/connector/services
WS_BASE_URL=

# Password for connector_admin user (used by the practitioner_taxonomy_repair call type).
CONNECTOR_ADMIN_PASSWORD=

# --- Repair Mode ---
# LOG_ONLY=true  -> loader logs SOAP envelopes instead of sending them to HRP.
#                   The repair jar still stages cpe_repair rows.
#                   Use to verify the SOAP shape before pushing real amends.
# LOG_ONLY=false -> Real mode. Loader pushes amends to HRP.
#
# run_repair.ps1 also accepts -LogOnlyOverride to flip true for a single run
# without editing this file.
LOG_ONLY=true

# --- WS Call Retry ---
# WS_RETRY_COUNT=0 disables retries (single attempt).
# WS_RETRY_HTTP_CODES: comma-separated HTTP status codes to retry on.
# Backoff is exponential: backoff_ms * 2^attempt, capped at max_backoff_ms.
# Retry-After response headers are honored when longer than the computed backoff.
WS_RETRY_COUNT=0
WS_RETRY_HTTP_CODES=408,429,502,503,504
WS_RETRY_BACKOFF_MS=1000
WS_RETRY_MAX_BACKOFF_MS=30000

# --- Database Setup ---
# Full path to sqlcmd.exe. install.ps1 uses this to optionally apply the DDL,
# and substitutes it into the deployed run_repair.ps1's $SQLCMD variable so
# the orchestrator's DB connectivity check and end-of-run count queries work.
SQLCMD_PATH=C:\Program Files\Microsoft SQL Server\Client SDK\ODBC\170\Tools\Binn\sqlcmd.exe

# --- Optional: custom NPI auto-derive query ---
# When run_repair.ps1 / the repair jar is invoked WITHOUT --npi-file, the jar
# auto-derives the NPI list via its built-in default query:
#   SELECT DISTINCT npi FROM <db.master.schema>.practitioner_taxonomy
#   WHERE taxonomy_source = 'NPPES'
# To scope tighter (e.g. only practitioners loaded during the v1.4.0 bug window
# via a cpe_load.load_run filter), set NPI_QUERY below to a SELECT returning
# ONE column of NPIs. install.ps1 writes it verbatim into
# PractitionerTaxonomyRepair.properties as db.npi_query. Leave blank for default.
NPI_QUERY=

# --- Optional: schema overrides ---
# Defaults below match the daily pipeline's standard schema layout. Override
# only if your environment uses non-default schema names.
DB_MASTER_SCHEMA=cpe_master
DB_REPAIR_SCHEMA=cpe_repair
DB_XREF_SCHEMA=cpe_xref
